NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
STORYBLOK_PREVIEW_TOKEN=your-preview-token-here
STORYBLOK_SPACE_ID=your-space-id-here

# On-demand ISR revalidation — used by /api/revalidate (Storyblok webhook endpoint).
# Generate a strong random value: openssl rand -hex 32
# Add the same value in Storyblok: Space Settings → Webhooks → Signing Secret.
STORYBLOK_WEBHOOK_SECRET=your-webhook-secret-here
