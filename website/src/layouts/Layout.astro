---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Weekly teachings fusing Torah wisdom with tai chi philosophy.' } = Astro.props;
const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..900,0..100;1,9..144,300..900,0..100&family=Mona+Sans:ital,wght@0,200..900;1,200..900&family=Frank+Ruhl+Libre:wght@300..900&display=swap" rel="stylesheet" />
</head>
<body>

<!-- Platform icon defs + Brand mark SVG -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <symbol id="icon-tiktok" viewBox="0 0 24 24"><path fill="currentColor" d="M16.6 5.82A4.28 4.28 0 0 1 15.54 2h-3.13v12.4a2.59 2.59 0 0 1-2.59 2.5 2.59 2.59 0 0 1-2.58-2.6 2.6 2.6 0 0 1 2.59-2.59c.28 0 .55.05.8.13V8.77a5.69 5.69 0 0 0-.8-.06 5.72 5.72 0 0 0-5.73 5.72 5.72 5.72 0 0 0 5.73 5.72 5.72 5.72 0 0 0 5.72-5.72V8.7a7.33 7.33 0 0 0 4.28 1.37V7a4.28 4.28 0 0 1-3.23-1.18z"/></symbol>
    <symbol id="icon-youtube" viewBox="0 0 24 24"><path fill="currentColor" d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.55A3.02 3.02 0 0 0 .5 6.19 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .5 5.81 3.02 3.02 0 0 0 2.12 2.14c1.88.55 9.38.55 9.38.55s7.5 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.5-5.81zM9.55 15.57V8.43L15.82 12l-6.27 3.57z"/></symbol>
    <symbol id="icon-instagram" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.97.24 2.44.41a4.08 4.08 0 0 1 2.51 2.51c.17.47.36 1.27.41 2.44.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.24 1.97-.41 2.44a4.37 4.37 0 0 1-2.51 2.51c-.47.17-1.27.36-2.44.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.97-.24-2.44-.41a4.37 4.37 0 0 1-2.51-2.51c-.17-.47-.36-1.27-.41-2.44C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.05-1.17.24-1.97.41-2.44a4.37 4.37 0 0 1 2.51-2.51c.47-.17 1.27-.36 2.44-.41C8.42 2.17 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a6.5 6.5 0 0 0-3.51 3.51C.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91a6.5 6.5 0 0 0 3.51 3.51c.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a6.5 6.5 0 0 0 3.51-3.51c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a6.5 6.5 0 0 0-3.51-3.51C19.1.33 18.22.13 16.95.07 15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/></symbol>
    <symbol id="icon-facebook" viewBox="0 0 24 24"><path fill="currentColor" d="M24 12.07C24 5.41 18.63 0 12 0S0 5.41 0 12.07c0 6.02 4.39 11.02 10.13 11.93v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.95.93-1.95 1.89v2.26h3.33l-.53 3.49h-2.8v8.44C19.61 23.09 24 18.09 24 12.07z"/></symbol>
    <radialGradient id="cedarWood" cx="35%" cy="30%" r="80%"><stop offset="0%" stop-color="#E3B888"/><stop offset="45%" stop-color="#B8823A"/><stop offset="100%" stop-color="#6A4622"/></radialGradient>
    <radialGradient id="linenLobe" cx="40%" cy="35%" r="80%"><stop offset="0%" stop-color="#FAF4E8"/><stop offset="100%" stop-color="#E9DDC1"/></radialGradient>
    <radialGradient id="navyLobe" cx="60%" cy="60%" r="80%"><stop offset="0%" stop-color="#2B3A5C"/><stop offset="100%" stop-color="#131E38"/></radialGradient>
    <g id="ttc-mark">
      <circle cx="60" cy="60" r="42" fill="url(#cedarWood)" stroke="#3D2A14" stroke-width=".8"/>
      <circle cx="60" cy="60" r="34" fill="none" stroke="#3D2A14" stroke-width=".4" opacity=".5"/>
      <g transform="translate(60 60)"><circle r="28" fill="url(#linenLobe)"/>
        <path d="M 0,-28 A 28,28 0 0,0 0,28 A 14,14 0 0,1 0,0 A 14,14 0 0,0 0,-28 Z" fill="url(#navyLobe)"/>
        <circle cx="0" cy="-14" r="3.2" fill="#FAF4E8"/><circle cx="0" cy="14" r="3.2" fill="#2B3A5C"/>
        <g transform="translate(0,-14) scale(.55)"><polygon points="0,-8 6.93,4 -6.93,4" fill="none" stroke="#9E7A3A" stroke-width="1.2"/><polygon points="0,8 6.93,-4 -6.93,-4" fill="none" stroke="#9E7A3A" stroke-width="1.2"/></g>
      </g>
      <defs><path id="arcTop" d="M 18,60 A 42,42 0 0,1 102,60"/></defs>
      <text font-family="Fraunces,serif" font-size="9" font-weight="600" letter-spacing="3" fill="#3D2A14"><textPath href="#arcTop" startOffset="50%" text-anchor="middle">TORAH</textPath></text>
      <text x="60" y="108" font-family="Fraunces,serif" font-size="8" font-weight="600" letter-spacing="3" fill="#3D2A14" text-anchor="middle">TAI CHI</text>
    </g>
  </defs>
</svg>

<nav class="site-nav">
  <a href="/" class="nav-brand">
    <svg viewBox="0 0 120 120" aria-hidden="true"><use href="#ttc-mark"/></svg>
    <span>Torah Tai Chi</span>
  </a>
  <div style="display:flex;align-items:center">
    <div class="nav-links">
      <a href="/" class={isActive('/') ? 'active' : ''}>Home</a>
      <a href="/videos" class={isActive('/videos') ? 'active' : ''}>Videos</a>
      <a href="/articles" class={isActive('/articles') ? 'active' : ''}>Articles</a>
      <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
    </div>
    <div class="nav-socials">
      <a href="https://tiktok.com/@torahtaichi" title="TikTok" target="_blank" rel="noopener"><svg><use href="#icon-tiktok"/></svg></a>
      <a href="https://youtube.com/@torahtaichi" title="YouTube" target="_blank" rel="noopener"><svg><use href="#icon-youtube"/></svg></a>
      <a href="https://instagram.com/torahtaichi" title="Instagram" target="_blank" rel="noopener"><svg><use href="#icon-instagram"/></svg></a>
    </div>
  </div>
</nav>

<slot />

<footer class="site-footer">
  <div class="footer-brand">&copy; 2026 Torah Tai Chi &middot; torahtaichi.com</div>
  <div class="footer-links">
    <a href="/videos">Videos</a>
    <a href="/articles">Articles</a>
    <a href="/about">About</a>
  </div>
  <div class="footer-socials">
    <a href="https://tiktok.com/@torahtaichi" title="TikTok" target="_blank" rel="noopener"><svg><use href="#icon-tiktok"/></svg></a>
    <a href="https://youtube.com/@torahtaichi" title="YouTube" target="_blank" rel="noopener"><svg><use href="#icon-youtube"/></svg></a>
    <a href="https://instagram.com/torahtaichi" title="Instagram" target="_blank" rel="noopener"><svg><use href="#icon-instagram"/></svg></a>
    <a href="https://facebook.com/torahtaichi" title="Facebook" target="_blank" rel="noopener"><svg><use href="#icon-facebook"/></svg></a>
  </div>
</footer>

</body>
</html>
