---
import Layout from '../../layouts/Layout.astro';
import { articles } from '../../data/articles';

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
}
---
<Layout
  title="Articles — Torah Tai Chi"
  description="Reflections on where wisdom lives in the body. Long-form essays, teachings, and reflections."
>

<header class="page-header stagger" style="max-width:720px">
  <div class="page-kicker">THE WRITINGS</div>
  <h1>From the writings</h1>
  <p class="page-subtitle"><em>Reflections on where wisdom lives in the body.</em></p>
</header>

<section class="articles-section stagger">
  {articles.map(a => (
    <a href={`/articles/${a.slug}`} class="article-entry">
      <span class="ae-tag">{a.category}</span>
      <h2 class="ae-title">{a.title}</h2>
      <p class="ae-excerpt">{a.excerpt}</p>
      <div class="ae-meta">{formatDate(a.date)} · {a.readMinutes} min read</div>
    </a>
  ))}
</section>

</Layout>

<style>
.articles-section{max-width:720px;margin:0 auto;padding:56px 48px 0}
@media(max-width:700px){.articles-section{padding:40px 20px 0}}

.article-entry{
  display:block;padding:32px 0;
  border-bottom:1px solid var(--ink-100);
  text-decoration:none;color:inherit;
  transition:all var(--trans);
}
.article-entry:first-child{padding-top:0}
.article-entry:last-child{border-bottom:none}
.article-entry:hover .ae-title{color:var(--cedar-700)}
.ae-tag{
  font-family:var(--ff-body);font-size:10.5px;
  letter-spacing:.16em;text-transform:uppercase;
  color:var(--cedar-600);font-weight:500;
  margin-bottom:10px;display:block;
}
.ae-title{
  font-family:var(--ff-display);font-weight:500;
  font-size:clamp(24px,3vw,30px);line-height:1.2;
  letter-spacing:-.015em;margin:0 0 10px 0;
  color:var(--ink-900);transition:color var(--trans);
  font-variation-settings:"opsz" 36,"SOFT" 30;
}
.ae-excerpt{
  font-family:var(--ff-reading);font-size:17px;line-height:1.55;
  color:var(--ink-500);margin:0 0 14px 0;
  font-variation-settings:"opsz" 18,"SOFT" 40;
  display:-webkit-box;-webkit-line-clamp:2;line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;
}
.ae-meta{
  font-family:var(--ff-display);font-style:italic;
  font-size:13px;color:var(--ink-400);
}
</style>
