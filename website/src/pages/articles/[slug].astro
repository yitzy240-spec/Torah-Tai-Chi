---
import Layout from '../../layouts/Layout.astro';
import { articles } from '../../data/articles';

export function getStaticPaths() {
  return articles.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = articles.find(a => a.slug === slug);
if (!article) return Astro.redirect('/articles');

const others = articles.filter(a => a.slug !== slug).slice(0, 2);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
}
---
<Layout
  title={`${article.title} — Torah Tai Chi`}
  description={article.subtitle}
>

<div class="back-wrap">
  <a href="/articles" class="back-link">← All writings</a>
</div>

<header class="ad-header stagger">
  <span class="ad-tag">{article.category}</span>
  <h1 set:html={article.title.replace(/([^:]+)$/, '<em>$1</em>')} />
  <p class="ad-deck">{article.subtitle}</p>
  <div class="ad-meta">{formatDate(article.date)} &middot; {article.readMinutes} min read</div>
</header>

<article class="ad-body stagger" set:html={article.body} />

<section class="continue-section">
  <h2 class="continue-head">Continue <em>reading</em></h2>
  <div class="continue-grid stagger">
    {others.map(a => (
      <a href={`/articles/${a.slug}`} class="a-card">
        <div class="a-tag">{a.category}</div>
        <h3 class="a-title">{a.title}</h3>
        <p class="a-excerpt">{a.excerpt}</p>
        <div class="a-meta">{formatDate(a.date)} &middot; {a.readMinutes} min read</div>
      </a>
    ))}
  </div>
</section>

</Layout>

<style>
.ad-header{max-width:720px;margin:0 auto;padding:20px 48px 0}
@media(max-width:700px){.ad-header{padding:16px 20px 0}}
.ad-tag{
  font-family:var(--ff-body);font-size:11px;
  letter-spacing:.2em;text-transform:uppercase;
  color:var(--cedar-600);font-weight:500;
  margin-bottom:20px;display:block;
}
.ad-header h1{
  font-family:var(--ff-display);font-weight:400;
  font-size:clamp(36px,5.4vw,60px);line-height:1.02;
  letter-spacing:-.03em;margin:0 0 20px 0;
  color:var(--ink-900);
  font-variation-settings:"opsz" 144,"SOFT" 25;
}
.ad-header h1 :global(em){font-style:italic;color:var(--cedar-600)}
.ad-deck{
  font-family:var(--ff-reading);font-style:italic;
  font-size:21px;line-height:1.45;color:var(--ink-500);
  margin:0 0 24px 0;
}
.ad-meta{
  font-family:var(--ff-display);font-style:italic;
  font-size:14px;color:var(--ink-400);
  padding-top:20px;border-top:1px solid var(--ink-100);
}

.ad-body{max-width:62ch;margin:48px auto 0;padding:0 48px}
@media(max-width:700px){.ad-body{padding:0 20px;margin-top:36px}}
.ad-body :global(p){
  font-family:var(--ff-reading);font-size:19px;line-height:1.65;
  color:var(--ink-800);margin:0 0 22px 0;
  font-variation-settings:"opsz" 19,"SOFT" 40;
}
.ad-body :global(.lead){
  font-size:22px;font-style:italic;color:var(--ink-700);
  line-height:1.55;margin-bottom:28px;
}
.ad-body :global(h2){
  font-family:var(--ff-display);font-weight:500;
  font-size:24px;letter-spacing:-.01em;
  margin:36px 0 16px 0;color:var(--ink-900);
}
.ad-body :global(.heb){font-family:var(--ff-hebrew);color:var(--ink-700);font-size:1.05em;margin:0 2px}
.ad-body :global(.ch){font-style:normal;color:var(--cedar-600);margin:0 2px}
.ad-body :global(em){color:var(--cedar-700)}
.ad-body :global(.pullquote){
  margin:40px 0;padding:24px 0 24px 28px;
  border-left:2px solid var(--cedar-400);
  font-family:var(--ff-display);font-style:italic;
  font-size:26px;line-height:1.35;color:var(--cedar-700);
}
.ad-body :global(.section-break){
  text-align:center;margin:40px 0;
  font-family:var(--ff-display);font-size:22px;
  color:var(--cedar-400);letter-spacing:.4em;
}

.continue-section{max-width:900px;margin:96px auto 0;padding:0 48px}
@media(max-width:700px){.continue-section{padding:0 20px;margin-top:64px}}
.continue-head{
  font-family:var(--ff-display);font-weight:400;
  font-size:clamp(22px,3vw,28px);letter-spacing:-.01em;
  margin:0 0 24px 0;color:var(--ink-900);
}
.continue-head em{font-style:italic;color:var(--ink-500)}
.continue-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
@media(max-width:700px){.continue-grid{grid-template-columns:1fr}}
</style>
