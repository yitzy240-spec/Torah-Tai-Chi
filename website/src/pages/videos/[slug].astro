---
import Layout from '../../layouts/Layout.astro';
import { getAllParshiot, getParshaBySlug, getNearbyParshiot } from '../../lib/parshiot';

export async function getStaticPaths() {
  const parshiot = await getAllParshiot();
  return parshiot.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const parsha = await getParshaBySlug(slug);
if (!parsha) return Astro.redirect('/videos');

const { prev, next } = await getNearbyParshiot(slug);
const nearby = [prev, next].filter(Boolean);

function formatScriptAsHtml(text: string): string {
  if (!text) return '';
  return text
    .split('\n\n')
    .map(para => para.trim())
    .filter(Boolean)
    .map((para, i) => i === 0 ? `<p>${para}</p>` : `<p>${para}</p>`)
    .join('\n');
}

const scriptHtml = parsha.script ? formatScriptAsHtml(parsha.script) : '';
---
<Layout
  title={`${parsha.name} — Torah Tai Chi`}
  description={`Parshat ${parsha.name}. A weekly teaching where Torah wisdom meets the body.`}
>

<div class="back-wrap">
  <a href="/videos" class="back-link">← All teachings</a>
</div>

<header class="vd-header stagger">
  <div class="vd-header-row">
    <h1 class="vd-eng">{parsha.name}<em>.</em></h1>
    {parsha.hebrewName && (
      <div class="vd-heb" lang="he" dir="rtl">{parsha.hebrewName}</div>
    )}
  </div>
  <div class="vd-meta">{parsha.book}</div>
</header>

<div class="vd-player-wrap stagger">
  <div class="vd-player">
    <div class="play">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
    </div>
    <div class="vlabel">{parsha.name} &middot; 48s</div>
  </div>
</div>

{scriptHtml && (
  <article class="vd-script stagger">
    <div class="vd-script-kicker"><span class="bar"></span>The teaching<span class="bar"></span></div>
    <Fragment set:html={scriptHtml} />
  </article>
)}

{nearby.length > 0 && (
  <section class="more-section">
    <div class="more-head">
      <h2>More <em>teachings</em></h2>
      <a href="/videos" class="more">All 52 parshiot →</a>
    </div>
    <div class="more-grid stagger">
      {nearby.map(p => p && (
        <a href={`/videos/${p.slug}`} class="v-card">
          <div class="thumb"><span class="dur">0:48</span></div>
          {p.hebrewName && <div class="v-heb" lang="he" dir="rtl">{p.hebrewName}</div>}
          <div class="v-name">{p.name}</div>
          <div class="v-book">{p.book}</div>
        </a>
      ))}
    </div>
  </section>
)}

</Layout>

<style>
.vd-header{
  max-width:900px;margin:0 auto;
  padding:32px 48px 0;
}
@media(max-width:700px){.vd-header{padding:24px 20px 0}}
.vd-header-row{
  display:flex;justify-content:space-between;align-items:baseline;
  gap:24px;flex-wrap:wrap;
}
.vd-heb{
  font-family:var(--ff-hebrew);font-weight:500;
  font-size:clamp(28px,4vw,42px);
  color:var(--ink-700);direction:rtl;text-align:right;
  letter-spacing:.01em;
}
.vd-eng{
  font-family:var(--ff-display);font-weight:400;
  font-size:clamp(40px,6vw,68px);line-height:.98;letter-spacing:-.03em;
  color:var(--ink-900);margin:0;
  font-variation-settings:"opsz" 144,"SOFT" 25;
}
.vd-eng em{font-style:italic;color:var(--cedar-600)}
.vd-meta{
  font-family:var(--ff-display);font-style:italic;
  font-size:14px;color:var(--ink-400);margin-top:16px;
}

.vd-player-wrap{
  max-width:900px;margin:40px auto 0;
  padding:0 48px;
  display:flex;justify-content:center;
}
@media(max-width:700px){.vd-player-wrap{padding:0 20px;margin-top:32px}}
.vd-player{
  width:min(380px,100%);
  aspect-ratio:9/16;
  background:var(--ink-900);
  border-radius:var(--r-xl);
  overflow:hidden;
  box-shadow:0 2px 0 rgba(35,27,16,.06),0 40px 80px -40px rgba(35,27,16,.35),0 0 0 1px rgba(35,27,16,.08);
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
@media(max-width:700px){.vd-player{max-width:360px}}
.vd-player .play{
  width:72px;height:72px;border-radius:50%;
  background:rgba(250,244,232,.15);backdrop-filter:blur(6px);
  display:grid;place-items:center;cursor:pointer;
  transition:all var(--trans);
}
.vd-player .play:hover{background:rgba(250,244,232,.25);transform:scale(1.06)}
.vd-player .play svg{width:32px;height:32px;color:var(--linen-50);margin-left:3px}
.vd-player .vlabel{
  position:absolute;bottom:16px;left:16px;right:16px;
  font-family:var(--ff-display);font-style:italic;font-size:13px;
  color:rgba(250,244,232,.6);
  text-align:center;
}

.vd-script{
  max-width:62ch;margin:64px auto 0;
  padding:0 48px;
}
@media(max-width:700px){.vd-script{padding:0 20px;margin-top:48px}}
.vd-script-kicker{
  font-family:var(--ff-body);font-size:11px;letter-spacing:.2em;
  text-transform:uppercase;color:var(--cedar-600);
  margin-bottom:20px;text-align:center;
  display:flex;align-items:center;justify-content:center;gap:10px;
}
.vd-script-kicker .bar{width:28px;height:1px;background:var(--cedar-400)}
.vd-script :global(p){
  font-family:var(--ff-reading);font-size:20px;line-height:1.7;
  color:var(--ink-800);margin:0 0 22px 0;
  font-variation-settings:"opsz" 20,"SOFT" 40;
}
.vd-script :global(p:first-of-type){
  font-size:22px;font-style:italic;color:var(--ink-700);
}

.more-section{
  max-width:1100px;margin:96px auto 0;
  padding:0 48px;
}
@media(max-width:700px){.more-section{padding:0 20px;margin-top:64px}}
.more-head{
  display:flex;align-items:baseline;justify-content:space-between;
  margin-bottom:24px;
}
.more-head h2{
  font-family:var(--ff-display);font-weight:400;
  font-size:clamp(22px,3vw,28px);letter-spacing:-.01em;
  margin:0;color:var(--ink-900);
  font-variation-settings:"opsz" 28,"SOFT" 30;
}
.more-head h2 em{font-style:italic;color:var(--ink-500)}
.more-head .more{font-family:var(--ff-body);font-size:13px;color:var(--ink-500);text-decoration:none}
.more-head .more:hover{color:var(--navy-700)}
.more-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
@media(max-width:700px){.more-grid{grid-template-columns:1fr 1fr;gap:14px}}
</style>
