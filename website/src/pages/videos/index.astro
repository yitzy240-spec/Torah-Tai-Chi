---
import Layout from '../../layouts/Layout.astro';
import { getAllParshiot } from '../../lib/parshiot';

const parshiot = await getAllParshiot();
const books = ['All', 'Genesis', 'Exodus', 'Leviticus', 'Numbers', 'Deuteronomy'];
---
<Layout
  title="Videos — Torah Tai Chi"
  description="Browse every parsha teaching. 52 weeks of Torah wisdom meeting the body."
>

<header class="page-header stagger">
  <div class="page-kicker">THE TEACHINGS</div>
  <h1>The weekly teachings</h1>
  <p class="page-subtitle"><em>Fifty-two parshiot. Fifty-two meetings of tradition and breath.</em></p>
</header>

<div class="filter-bar" id="filter-bar">
  {books.map(b => (
    <button
      class={`filter-pill${b === 'All' ? ' active' : ''}`}
      data-book={b}
    >
      {b}
    </button>
  ))}
</div>

<section class="video-section">
  <div class="video-grid stagger" id="video-grid">
    {parshiot.map(p => (
      <a
        href={`/videos/${p.slug}`}
        class="v-card"
        data-book={p.book}
      >
        <div class="thumb"><span class="dur">0:48</span></div>
        {p.hebrewName && <div class="v-heb" lang="he" dir="rtl">{p.hebrewName}</div>}
        <div class="v-name">{p.name}</div>
        <div class="v-book">{p.book}</div>
      </a>
    ))}
  </div>
</section>

</Layout>

<style>
.filter-bar{
  max-width:1400px;margin:0 auto;
  padding:40px 48px 0;
  display:flex;justify-content:center;gap:8px;flex-wrap:wrap;
}
@media(max-width:700px){.filter-bar{padding:32px 20px 0;gap:6px}}

.filter-pill{
  font-family:var(--ff-body);font-size:13px;font-weight:500;
  padding:10px 22px;min-height:44px;
  border-radius:999px;border:1px solid var(--ink-100);
  background:transparent;color:var(--ink-500);
  cursor:pointer;transition:all var(--trans);
  display:inline-flex;align-items:center;
}
.filter-pill:hover{border-color:var(--ink-300);color:var(--ink-900)}
.filter-pill.active{background:var(--navy-800);color:var(--linen-50);border-color:var(--navy-800)}

.video-section{
  max-width:1400px;margin:0 auto;
  padding:40px 48px 0;
}
@media(max-width:700px){.video-section{padding:32px 20px 0}}

.video-grid{
  display:grid;grid-template-columns:repeat(4,1fr);gap:20px;
}
@media(max-width:1000px){.video-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.video-grid{grid-template-columns:1fr 1fr;gap:14px}}
</style>

<script>
const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
const cards = document.querySelectorAll<HTMLElement>('.v-card');

pills.forEach(pill => {
  pill.addEventListener('click', () => {
    pills.forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    const book = pill.dataset.book;
    cards.forEach(card => {
      if (book === 'All' || card.dataset.book === book) {
        (card as HTMLElement).style.display = '';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  });
});
</script>
