KIE_AI_API_KEY=your-kie-ai-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Which provider to call Claude through first. The other runs once as
# fallback if the primary's retry budget is exhausted. Default:
# "openrouter" (Kie's relay has been unreliable on long-prompt calls;
# OpenRouter routes directly to Anthropic). Set to "kie" to flip back
# when Kie stabilizes — Kie is cheaper for normal traffic.
# When openrouter is primary, OPENROUTER_API_KEY must be set.
CLAUDE_PRIMARY_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-your-key-here

# Shared secret — required on the Modal trigger() endpoint to prevent
# unauthenticated callers from spawning paid Seedance generations. Must
# match the value set in the Modal secret bundle (torah-tai-chi-env)
# AND in Vercel (dashboard project, Production + Preview).
PIPELINE_TRIGGER_SECRET=
