NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
MODAL_WORKER_URL=https://<your-modal-app>.modal.run
# Shared secret sent as x-pipeline-secret to the Modal trigger() endpoint.
# Must match the value in the Modal secret bundle (torah-tai-chi-env).
# Distinct from PIPELINE_WEBHOOK_SECRET (outbound webhook from Modal).
PIPELINE_TRIGGER_SECRET=<random-hex-string>

# Storyblok
STORYBLOK_SPACE_ID=<space-id>
STORYBLOK_MANAGEMENT_TOKEN=<management-token>
STORYBLOK_PREVIEW_TOKEN=<preview-token>

# Buffer — optional; when set, the system health strip checks Buffer connectivity
# and schedule-all works. Leave blank to skip Buffer checks.
BUFFER_ACCESS_TOKEN=

# Claude provider order for the Modal pipeline. Default: "openrouter"
# (primary), with Kie as fallback. Set to "kie" to flip back when Kie
# stabilizes. Read by the Modal worker; the dashboard itself doesn't
# call Claude directly, but this env is documented here for parity
# with the Modal secret bundle (torah-tai-chi-env).
CLAUDE_PRIMARY_PROVIDER=openrouter
